rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isProjectOwner(projectId) {
      return isAuthenticated() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "eitan2006@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "eitan2007@gmail.com" && request.auth.token.email_verified == true)); // Default admins
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() < 255;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'ownerId', 'name']) &&
             data.id is string && data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidFile(data) {
      return data.keys().hasAll(['id', 'projectId', 'path', 'content']) &&
             data.id is string && data.projectId is string &&
             data.path is string && data.path.size() > 0 &&
             data.content is string && data.content.size() < 1000000;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'projectId', 'title', 'completed', 'createdAt']) &&
             data.id is string && data.projectId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.completed is bool;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'projectId', 'role', 'content', 'timestamp']) &&
             data.id is string && data.projectId is string &&
             data.role is string && data.role.size() > 0 && data.role.size() < 50 &&
             data.content is string && data.content.size() < 1000000 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 2000));
    }

    function isValidSkill(data) {
      return data.keys().hasAll(['id', 'name', 'description', 'content', 'category']) &&
             data.id is string && data.name is string && data.name.size() > 0 &&
             data.description is string && data.content is string && data.category is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && isValidProject(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      
      match /files/{fileId} {
        allow read: if isProjectOwner(projectId);
        allow create: if isProjectOwner(projectId) && isValidFile(request.resource.data);
        allow update: if isProjectOwner(projectId) && isValidFile(request.resource.data);
        allow delete: if isProjectOwner(projectId);
      }

      match /tasks/{taskId} {
        allow read: if isProjectOwner(projectId);
        allow create: if isProjectOwner(projectId) && isValidTask(request.resource.data);
        allow update: if isProjectOwner(projectId) && isValidTask(request.resource.data);
        allow delete: if isProjectOwner(projectId);
      }

      match /messages/{messageId} {
        allow read: if isProjectOwner(projectId);
        allow create: if isProjectOwner(projectId) && isValidMessage(request.resource.data);
        allow update: if isProjectOwner(projectId) && isValidMessage(request.resource.data);
        allow delete: if isProjectOwner(projectId);
      }
    }

    match /availableSkills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
