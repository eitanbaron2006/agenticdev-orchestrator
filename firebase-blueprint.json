{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A development project containing files",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "projectType": { "type": "string", "description": "Project type ID (static-site, react-cdn, nextjs, vue-cdn, svelte-cdn, express-api, flask-api)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastModified": { "type": "string", "format": "date-time" },
        "globalSkills": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "agentConfigs": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "creativity": { "type": "number" },
              "focus": { "type": "string" },
              "tools": { 
                "type": "array",
                "items": { "type": "string" }
              },
              "skills": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      },
      "required": ["id", "ownerId", "name"]
    },
    "File": {
      "title": "File",
      "description": "A file within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "path": { "type": "string" },
        "content": { "type": "string" },
        "language": { "type": "string" },
        "lastModified": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "path", "content"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "title", "completed", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "projectId", "role", "content", "timestamp"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A reusable skill or knowledge base for agents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "name", "description", "content", "category"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project metadata"
    },
    "/projects/{projectId}/files/{fileId}": {
      "schema": "File",
      "description": "Files associated with a project"
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks associated with a project"
    },
    "/projects/{projectId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages associated with a project"
    },
    "/availableSkills/{skillId}": {
      "schema": "Skill",
      "description": "Library of available skills to download"
    }
  }
}
